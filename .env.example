# ============================================
# Base de Datos v1 — Origen (Google Cloud)
# ============================================
V1_HOST=136.116.247.253
V1_PORT=5432
V1_DATABASE=postgres
V1_SCHEMA=toniclife
V1_USER=                       # ** OBLIGATORIO **
V1_PASSWORD=                   # ** OBLIGATORIO **

# ============================================
# Base de Datos v2 — Destino (AlloyDB)
# ============================================
V2_HOST=34.70.18.38
V2_PORT=5432
V2_DATABASE=toniclife_db_v2
V2_SCHEMA=tonic
V2_USER=                       # ** OBLIGATORIO **
V2_PASSWORD=                   # ** OBLIGATORIO **

# ============================================
# Encriptacion de contrasenas
# ============================================
KEY_GCM=                       # ** OBLIGATORIO ** Llave historica (requerida por config)

# ============================================
# Configuracion de migracion
# ============================================
BATCH_SIZE=5000                # Registros por lote (default: 5000)
LOG_LEVEL=info                 # debug | info | warn | error (default: info)

# ============================================
# Google Cloud Storage (opcional)
# ============================================
# Si GCS_ENABLED=true, los archivos se descargan de tonic-life.net
# y se suben al bucket de GCS. Si es false, se usan URLs legacy.
GCS_ENABLED=false
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_CREDENTIALS=               # JSON completo del service account en UNA linea
GCS_CONCURRENCY=8              # Descargas/subidas simultaneas (default: 8)
GCS_RETRY_ATTEMPTS=3           # Reintentos por archivo fallido (default: 3)
